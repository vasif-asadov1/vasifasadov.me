---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

// 1. FRONTMATTER ALANI (Server-side JavaScript/TypeScript)
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{title} | Data Science & AI Research</title>

        <link
          rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
          integrity="sha384-n8MVd4RsNIU0tAv4ctWMnEYPzhcH8DnSVRqWVZiALPu5W38J8lxhz3at6WPLOc7v"
          crossorigin="anonymous"
        />
    </head>
    
    <body class="bg-gray-50 text-gray-900 dark:bg-gradient-to-br dark:from-[#1e212b] dark:to-[#14161c] dark:text-slate-200 min-h-screen flex flex-col antialiased selection:bg-teal-500 selection:text-white">
        
        <Navbar />

        <main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <slot />
        </main>

        </body>
</html>